root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.sh]
switch_case_indent = true
indent_style = space
indent_size = 2
tab_width = 2

[*.js]
indent_style = space
indent_size = 2
tab_width = 2

[*.css]
indent_style = space
indent_size = 4
tab_width = 4
